# By default only the base compose.yaml is loaded.
# To also expose the database and Tomcat debug ports, change to:
# COMPOSE_FILE=compose.yaml:compose.override.yaml
COMPOSE_FILE=compose.yaml

SERVICE_NAME=pihsl
OPENMRS_IMAGE_TAG=latest

# Database image — mysql:5.6 is
# Use mariadb:10.11.7 to match the default for OpenMRS 2.5+
DB_IMAGE=mysql:5.6

# Credentials — override these for non-development deployments
OMRS_DB_USER=openmrs
OMRS_DB_PASSWORD=openmrs
MYSQL_ROOT_PASSWORD=openmrs

# Ports
TOMCAT_HTTP_PORT=8080
MYSQL_PORT=3306
TOMCAT_DEBUG_PORT=1044

# PIH configuration profile
PIH_CONFIG=sierraLeone,sierraLeone-kgh,sierraLeone-kgh-test

# OpenMRS runtime feature flags
DBEVENT_ENABLED=false
ACTIVITYLOG_ENABLED=false

# Memory limits
DB_MEMORY_LIMIT=2g
OPENMRS_MEMORY_LIMIT=4g
OMRS_JAVA_MEMORY_OPTS=-Xms512m -Xmx2g -XX:NewSize=128m

# Database tuning
DB_MAX_ALLOWED_PACKET=1G
DB_INNODB_BUFFER_POOL_SIZE=2G
